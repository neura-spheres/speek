{
  "name": "speek",
  "displayName": "Speek",
  "description": "Syntax highlighting and run support for Speek (.spk) files",
  "version": "0.2.0",
  "publisher": "speek-lang",
  "engines": {
    "vscode": "^1.79.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/neura-spheres/speek"
  },
  "activationEvents": [
    "onLanguage:speek"
  ],
  "contributes": {
    "languages": [
      {
        "id": "speek",
        "aliases": ["Speek", "speek"],
        "extensions": [".spk"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/speekLogo.png",
          "dark": "./icons/speekLogo.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "speek",
        "scopeName": "source.speek",
        "path": "./syntaxes/speek.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "speek.runFile",
        "title": "Run Speek File",
        "category": "Speek",
        "icon": "$(play)"
      },
      {
        "command": "speek.debugFile",
        "title": "Run Speek File (Debug)",
        "category": "Speek",
        "icon": "$(debug-alt)"
      },
      {
        "command": "speek.checkFile",
        "title": "Check Speek File",
        "category": "Speek",
        "icon": "$(check)"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "speek.runFile",
          "when": "resourceExtname == .spk",
          "group": "navigation@1"
        },
        {
          "command": "speek.debugFile",
          "when": "resourceExtname == .spk",
          "group": "navigation@2"
        }
      ],
      "editor/context": [
        {
          "command": "speek.runFile",
          "when": "resourceExtname == .spk",
          "group": "speek"
        },
        {
          "command": "speek.checkFile",
          "when": "resourceExtname == .spk",
          "group": "speek"
        }
      ]
    },
    "keybindings": [
      {
        "command": "speek.runFile",
        "key": "f5",
        "when": "resourceExtname == .spk && editorTextFocus"
      }
    ]
  },

  "configurationDefaults": {
    "editor.tokenColorCustomizations": {
      "textMateRules": [
        {
          "scope": "variable.other.speek",
          "settings": { "foreground": "#9CDCFE" }
        },
        {
          "scope": "entity.name.type.speek",
          "settings": { "foreground": "#4EC9B0", "fontStyle": "italic" }
        },
        {
          "scope": "keyword.operator.arithmetic.speek",
          "settings": { "foreground": "#F4A261" }
        },
        {
          "scope": "keyword.operator.comparison.speek",
          "settings": { "foreground": "#DCDCAA" }
        },
        {
          "scope": "keyword.control.speek",
          "settings": { "foreground": "#C586C0" }
        },
        {
          "scope": "keyword.other.speek",
          "settings": { "foreground": "#858585" }
        },
        {
          "scope": "support.function.speek",
          "settings": { "foreground": "#4FC1FF" }
        },
        {
          "scope": "support.function.builtin.speek",
          "settings": { "foreground": "#DCDCAA" }
        }
      ]
    }
  }
}
