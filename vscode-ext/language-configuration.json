{
  "comments": {
    "lineComment": "#"
  },
  "autoClosingPairs": [
    { "open": "\"", "close": "\"" }
  ],
  "surroundingPairs": [
    { "open": "\"", "close": "\"" }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(loop|if|else if|else|define|repeat|while|for|when|for each|go through).*",
    "decreaseIndentPattern": "^\\s*(end|else|done|finish|close|stop).*"
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
